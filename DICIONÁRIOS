dados = {
    "nome": "Lucas",
    "idade": 28,
    "cidade": "Curitiba",
    "profissao": "Analista",
    "hobby": "Fotografia"
}

def exibir(d):
    for chave, valor in d.items():
        print(f"  {chave}: {valor}")

print("Dicionario inicial:")
exibir(dados)

print("\nChaves disponiveis:", list(dados.keys()))
chave = input("Chave para remover com pop(): ").strip().lower()
removido = dados.pop(chave, None)
if removido:
    print(f"'{chave}: {removido}' removido.")
else:
    print(f"Chave '{chave}' nao encontrada.")

ultimo = dados.popitem()
print(f"Ultimo item removido com popitem(): '{ultimo[0]}: {ultimo[1]}'")

print("\nApós remoções:")
