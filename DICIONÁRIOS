nova_chave = input("\nNova chave para update(): ").strip().lower()
novo_valor = input("Novo valor: ").strip()
dados.update({nova_chave: novo_valor})

print("\nDicionario final:")
exibir(dados)

#11
usuarios = {"Ana": 28, "Carlos": 35, "Beatriz": 22}

def exibir(d):
    for k, v in d.items():
        print(f"  {k}: {v}")

while True:
    print("\n--- MENU ---")
    opcoes = ["1.Exibir", "2.Buscar", "3.Adicionar", "4.Atualizar",
              "5.Remover", "6.Remover ultimo", "7.Copiar",
              "8.Fromkeys", "9.Update", "10.Limpar", "11.Dict()", "0.Sair"]
    print(" | ".join(opcoes))
    op = input("Opcao: ").strip()

    if op == "1":
        print("Nomes:", list(usuarios.keys()))
        print("Idades:", list(usuarios.values()))
        print("Pares:"); exibir(usuarios)

    elif op == "2":
        nome = input("Nome: ").capitalize()
        resultado = usuarios.get(nome)
        print(f"{nome}: {resultado} anos" if resultado else "Usuario nao encontrado.")

    elif op == "3":
        nome = input("Nome: ").capitalize()
        idade = int(input("Idade: "))
        usuarios[nome] = idade
        print(f"{nome} adicionado.")

    elif op == "4":
        nome = input("Nome: ").capitalize()
        if nome in usuarios:
            usuarios[nome] = int(input("Nova idade: "))
            print("Idade atualizada.")
        else:
            print("Usuario nao encontrado.")

    elif op == "5":
        nome = input("Nome: ").capitalize()
        removido = usuarios.pop(nome, None)
        print(f"{nome} removido." if removido else "Usuario nao encontrado.")

    elif op == "6":
        if usuarios:
            item = usuarios.popitem()
            print(f"Removido: {item[0]}: {item[1]}")
        else:
            print("Dicionario vazio.")

    elif op == "7":
        copia = usuarios.copy()
        nome = input("Nome para alterar na copia: ").capitalize()
        if nome in copia:
            copia[nome] = int(input("Nova idade na copia: "))
        print("Original:"); exibir(usuarios)
        print("Copia:"); exibir(copia)

    elif op == "8":
        nomes = [n.strip().capitalize() for n in input("Nomes (virgula): ").split(",")]
        padrao = int(input("Idade padrao: "))
        novo = dict.fromkeys(nomes, padrao)
        print("Novo dicionario:"); exibir(novo)
        if input("Mesclar com principal? (s/n): ") == "s":
            usuarios.update(novo)

    elif op == "9":
        pares = [n.strip().capitalize() for n in input("Nomes (virgula): ").split(",")]
        novo = {nome: int(input(f"Idade de {nome}: ")) for nome in pares}
        usuarios.update(novo)
        print("Dicionario atualizado."); exibir(usuarios)

    elif op == "10":
        if input("Limpar tudo? (s/n): ") == "s":
            usuarios.clear()
            print("Dicionario limpo.")

    elif op == "11":
        n = int(input("Quantos pares? "))
        tuplas = [(input(f"Chave {i+1}: ").capitalize(), int(input(f"Valor {i+1}: "))) for i in range(n)]
        novo = dict(tuplas)
        print("Dicionario criado:"); exibir(novo)
        if input("Mesclar com principal? (s/n): ") == "s":
            usuarios.update(novo)

    elif op == "0":
        print("Encerrando..."); break

    else:
        print("Opcao invalida.")
